@{
    ViewData["Title"] = "Home Page";
    ViewData["Page"] = "register";
}

<div class="Mother-logIn">
        <div class="login-container">
            <p class="Login-Title">Vivid<span class="Color-title">Path</span></p>

            <div class="logindesc-card">
            <p class="Login">Register</p>
            <p class="Login-desc">Welcome to Where Creativity Finds Its Path.</p>
            </div>

            <div class="Users-Card">
                <div class="input-group">          
                <label>Username</label>  
                <input type="text" name="username" required />
            </div>

            <div class="input-group">
                <label>Email</label>
                <input type="text" name="email" required />
                </div>

            <div class="input-group">
                <label>Password</label>
                <input type="password" name="password" required />
                </div>

            <div class="input-group">
                <label>Confirm Password</label>
                <input type="password" name="password" required />
                </div>

        </div>
            
    </div>
        <div class="loggin-formm">
            <button class="Login-button">Register</button>
            <p class="register-foots">
                Already have an account? 
                <a asp-controller="Home" asp-action="Login" class="regiss">Login</a>
            </p>
        </div>
    </div>
</div>

